# SmartSpaces Environment Variables
# Copy to .env and fill in your values

# API keys (comma-separated). If not set, a random key is generated on startup.
SMARTSPACES_API_KEYS=your-api-key-here

# CORS allowed origins (comma-separated). Leave empty for same-origin only.
SMARTSPACES_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# KinCony device IP (for the KinCony adapter)
KINCONY_IP=192.168.0.90
